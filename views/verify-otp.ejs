<%- include("partials/head", { title }) %>
  <main class="page">
    <div class="site-header">
      <a class="brand" href="/">Twitter Clone</a>
      <a class="btn btn-secondary" href="/forgot-password">Request new OTP</a>
    </div>

    <section class="form-card">
      <p class="brand">Security check</p>
      <h1>Verify OTP</h1>
      <% if (formError) { %><div class="alert alert-error"><%= formError %></div><% } %>
      <form action="/verify-otp" method="POST">
        <div class="form-grid">
          <div class="form-group full">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" value="<%= values.email %>" />
            <% if (errors.email) { %><span class="error-text"><%= errors.email %></span><% } %>
          </div>
          <div class="form-group full">
            <label for="otp">OTP</label>
            <input id="otp" name="otp" value="<%= values.otp %>" inputmode="numeric" />
            <% if (errors.otp) { %><span class="error-text"><%= errors.otp %></span><% } %>
          </div>
        </div>
        <div class="hero-actions">
          <button class="btn btn-primary" type="submit">Verify OTP</button>
        </div>
      </form>
    </section>
  </main>
<%- include("partials/footer") %>
