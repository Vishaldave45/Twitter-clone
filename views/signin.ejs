<%- include("partials/head", { title }) %>
  <main class="page">
    <div class="site-header">
      <a class="brand" href="/">Twitter Clone</a>
      <div class="header-actions">
        <a class="btn btn-secondary" href="/signup">Create account</a>
      </div>
    </div>

    <section class="form-card">
      <p class="brand">Welcome back</p>
      <h1>Sign in</h1>
      <p>Use your email or username to access the protected app shell.</p>

      <% if (formError) { %>
        <div class="alert alert-error"><%= formError %></div>
      <% } %>

      <form action="/signin" method="POST">
        <div class="form-grid">
          <div class="form-group full">
            <label for="login">Email or username</label>
            <input id="login" name="login" value="<%= values.login %>" />
            <% if (errors.login) { %><span class="error-text"><%= errors.login %></span><% } %>
          </div>

          <div class="form-group full">
            <label for="password">Password</label>
            <input id="password" name="password" type="password" />
            <% if (errors.password) { %><span class="error-text"><%= errors.password %></span><% } %>
          </div>
        </div>

        <div class="forgot_password">
          <a href="/forgot-password">Forgot password?</a>
        </div>

        <div class="hero-actions">
          <button class="btn btn-primary" type="submit">Sign in</button>
        </div>
      </form>
    </section>
  </main>
<%- include("partials/footer") %>
