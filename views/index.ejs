<%- include("partials/head", { title }) %>
  <main class="page">
    <section class="hero">
      <div class="hero-copy">
        <p class="brand">Twitter Clone</p>
        <h1>Start the social graph with secure auth first.</h1>
        <p>
          This starter gives you the initial Twitter-style account flow: create an account,
          upload an avatar, sign in securely, and land on a protected home screen.
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="/signup">Create account</a>
          <a class="btn btn-secondary" href="/signin">Sign in</a>
        </div>
      </div>
      <div class="form-card">
        <p class="brand">What is included</p>
        <h1>Auth foundation</h1>
        <p>
          Express routing, MySQL persistence, password hashing, JWT cookies, multer uploads,
          and validation written in TypeScript.
        </p>
      </div>
    </section>
  </main>
<%- include("partials/footer") %>
